!uploads/menu/.gitkeep
!uploads/qr/.gitkeep
!uploads/receipts/.gitkeep

# IDE
.vscode/
.idea/
*.sublime-*

# OS Files
.DS_Store
Thumbs.db

# Logs
*.log
error_log

# Temp files
*.tmp
*.bak
*.swp
*~

# Config (if contains sensitive data)
# config/database.php

# Vendor (if using composer)
vendor/
node_modules/
